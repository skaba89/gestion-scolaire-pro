# =====================================================
# SchoolFlow Pro - Template d'Environnement Déploiement
# Copier ce fichier vers .env et remplir les variables
# =====================================================

# --- BASE DE DONNÉES (Supabase/PostgreSQL) ---
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGEME_SECURE_PASSWORD

# --- SÉCURITÉ & JWT ---
# Générer une clé de 32+ caractères
JWT_SECRET=CHANGEME_SECURE_JWT_SECRET
# Générer une clé de 64+ caractères
SECRET_KEY_BASE=CHANGEME_SECURE_SECRET_BASE
# Clé de 16 caractères exactement pour Realtime AES-128
DB_ENC_KEY=CHANGEME_16_CHARS

# --- SUPABASE KEYS ---
# Ces clés doivent être générées en cohérence avec le JWT_SECRET
SUPABASE_ANON_KEY=CHANGEME_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=CHANGEME_SERVICE_ROLE_KEY

# --- NETWORKING ---
# L'IP ou le domaine DNS de votre serveur
SERVER_EXTERNAL_IP=localhost
# Ports par défaut
KONG_HTTP_PORT=8000
STUDIO_PORT=3001

# --- IDENTITY PROVIDER (KEYCLOAK) ---
# Désactivé par défaut si non utilisé
KEYCLOAK_ENABLED=true
KEYCLOAK_CLIENT_ID=schoolflow-supabase
KEYCLOAK_CLIENT_SECRET=supabase-secret
KEYCLOAK_URL=http://localhost:8081/realms/schoolflow

# --- MAILING (SMTP) ---
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME="SchoolFlow Admin"
SMTP_ADMIN_EMAIL=admin@example.com

# --- SERVICES TIERS ---
RESEND_API_KEY=
STRIPE_SECRET_KEY=
