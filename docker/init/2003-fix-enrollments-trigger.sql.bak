-- Fix Enrollments Table and View

-- 1. ENHANCE class_enrollments TABLE
-- It needs to store academic_year, tenant, etc.
ALTER TABLE public.class_enrollments ADD COLUMN IF NOT EXISTS tenant_id UUID REFERENCES public.tenants(id) ON DELETE CASCADE;
ALTER TABLE public.class_enrollments ADD COLUMN IF NOT EXISTS academic_year_id UUID REFERENCES public.academic_years(id) ON DELETE CASCADE;
ALTER TABLE public.class_enrollments ADD COLUMN IF NOT EXISTS level_id UUID REFERENCES public.levels(id) ON DELETE SET NULL; -- Snapshot of level at enrollment

-- Fix permissions for the underlying table
ALTER TABLE public.class_enrollments ENABLE ROW LEVEL SECURITY;
DROP POLICY IF EXISTS "allow_all_class_enrollments" ON public.class_enrollments;
CREATE POLICY "allow_all_class_enrollments" ON public.class_enrollments FOR ALL USING (true) WITH CHECK (true);
GRANT ALL ON public.class_enrollments TO anon, authenticated, service_role;

-- 2. RECREATE ENROLLMENTS VIEW
DROP VIEW IF EXISTS public.enrollments CASCADE;

CREATE OR REPLACE VIEW public.enrollments AS
SELECT 
  ce.id,
  ce.class_id as classroom_id, -- Expose as classroom_id to match frontend
  ce.student_id,
  ce.status,
  ce.academic_year_id,
  ce.level_id,
  ce.tenant_id,
  c.name as classroom_name, -- Additional info
  ce.created_at,
  ce.updated_at
FROM public.class_enrollments ce
LEFT JOIN public.classrooms c ON ce.class_id = c.id;

-- Grant permissions
GRANT SELECT, INSERT, UPDATE, DELETE ON public.enrollments TO authenticated, service_role;

-- 3. CREATE INSTEAD OF INSERT TRIGGER
-- This allows PostgREST to "insert" into the view by redirecting to the table
CREATE OR REPLACE FUNCTION public.insert_enrollment()
RETURNS TRIGGER AS $$
BEGIN
  INSERT INTO public.class_enrollments (
    tenant_id,
    student_id,
    class_id, -- Map classroom_id to class_id
    academic_year_id,
    level_id,
    status
  ) VALUES (
    NEW.tenant_id,
    NEW.student_id,
    NEW.classroom_id,
    NEW.academic_year_id,
    NEW.level_id,
    NEW.status
  )
  RETURNING 
    id, class_id, student_id, status, academic_year_id, level_id, tenant_id, created_at, updated_at
  INTO 
    NEW.id, NEW.classroom_id, NEW.student_id, NEW.status, NEW.academic_year_id, NEW.level_id, NEW.tenant_id, NEW.created_at, NEW.updated_at;
    
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trigger_insert_enrollment ON public.enrollments;
CREATE TRIGGER trigger_insert_enrollment
INSTEAD OF INSERT ON public.enrollments
FOR EACH ROW EXECUTE FUNCTION public.insert_enrollment();

-- 4. CREATE INSTEAD OF DELETE TRIGGER (Optional but good)
CREATE OR REPLACE FUNCTION public.delete_enrollment()
RETURNS TRIGGER AS $$
BEGIN
  DELETE FROM public.class_enrollments WHERE id = OLD.id;
  RETURN OLD;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trigger_delete_enrollment ON public.enrollments;
CREATE TRIGGER trigger_delete_enrollment
INSTEAD OF DELETE ON public.enrollments
FOR EACH ROW EXECUTE FUNCTION public.delete_enrollment();

-- 5. CREATE INSTEAD OF UPDATE TRIGGER (Optional)
CREATE OR REPLACE FUNCTION public.update_enrollment()
RETURNS TRIGGER AS $$
BEGIN
  UPDATE public.class_enrollments
  SET 
    status = NEW.status,
    class_id = NEW.classroom_id,
    updated_at = now()
  WHERE id = OLD.id;
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trigger_update_enrollment ON public.enrollments;
CREATE TRIGGER trigger_update_enrollment
INSTEAD OF UPDATE ON public.enrollments
FOR EACH ROW EXECUTE FUNCTION public.update_enrollment();
