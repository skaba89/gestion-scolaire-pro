-- Test RLS pour user_roles
-- Ce script simule une requête frontend pour vérifier si les politiques RLS fonctionnent

-- 1. Récupérer un utilisateur avec un rôle
SELECT 'Test 1: Récupération d''un utilisateur admin' AS test;
SELECT u.id, u.email, ur.role, ur.tenant_id
FROM auth.users u
LEFT JOIN public.user_roles ur ON u.id = ur.user_id
WHERE ur.role = 'TENANT_ADMIN'
LIMIT 1;

-- 2. Vérifier les politiques RLS sur user_roles
SELECT 'Test 2: Politiques RLS sur user_roles' AS test;
SELECT schemaname, tablename, policyname, permissive, roles, cmd, qual
FROM pg_policies
WHERE tablename = 'user_roles';

-- 3. Vérifier que RLS est activé
SELECT 'Test 3: RLS activé sur user_roles?' AS test;
SELECT relname, relrowsecurity
FROM pg_class
WHERE relname = 'user_roles';

-- 4. Test de la fonction get_user_tenant
SELECT 'Test 4: Test de get_user_tenant()' AS test;
SELECT public.get_user_tenant('10da6837-4c92-4ac0-a8cc-bd64079cd30f'::uuid) AS tenant_id;

-- 5. Test de la fonction has_role
SELECT 'Test 5: Test de has_role()' AS test;
SELECT public.has_role('10da6837-4c92-4ac0-a8cc-bd64079cd30f'::uuid, 'TENANT_ADMIN') AS has_admin_role;

-- 6. Requête directe sans RLS (en tant que postgres)
SELECT 'Test 6: Requête directe user_roles (sans RLS)' AS test;
SELECT user_id, role, tenant_id
FROM public.user_roles
WHERE user_id = '10da6837-4c92-4ac0-a8cc-bd64079cd30f'::uuid;
