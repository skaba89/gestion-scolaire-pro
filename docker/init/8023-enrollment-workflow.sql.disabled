-- Phase 5: Enrollment Workflow 2.0

-- 1. Ensure Enrollment Status Enum is comprehensive (We already have some, let's verify/extend)
-- Current labels from previous check: ACTIVE, COMPLETED, DROPPED, PENDING
-- Proposed: PENDING, APPROVED, ACTIVE, TRANSFERRED, DROPPED, GRADUATED, ARCHIVED

DO $$
BEGIN
    -- Add missing values if needed (PostgreSQL doesn't support IF NOT EXISTS for ENUM values directly in a clean way across versions)
    -- We'll check presence and ALTER
    IF NOT EXISTS (SELECT 1 FROM pg_enum JOIN pg_type ON pg_enum.enumtypid = pg_type.oid WHERE pg_type.typname = 'enrollment_status' AND enumlabel = 'APPROVED') THEN
        ALTER TYPE public.enrollment_status ADD VALUE 'APPROVED';
    END IF;
    IF NOT EXISTS (SELECT 1 FROM pg_enum JOIN pg_type ON pg_enum.enumtypid = pg_type.oid WHERE pg_type.typname = 'enrollment_status' AND enumlabel = 'TRANSFERRED') THEN
        ALTER TYPE public.enrollment_status ADD VALUE 'TRANSFERRED';
    END IF;
    IF NOT EXISTS (SELECT 1 FROM pg_enum JOIN pg_type ON pg_enum.enumtypid = pg_type.oid WHERE pg_type.typname = 'enrollment_status' AND enumlabel = 'GRADUATED') THEN
        ALTER TYPE public.enrollment_status ADD VALUE 'GRADUATED';
    END IF;
    IF NOT EXISTS (SELECT 1 FROM pg_enum JOIN pg_type ON pg_enum.enumtypid = pg_type.oid WHERE pg_type.typname = 'enrollment_status' AND enumlabel = 'ARCHIVED') THEN
        ALTER TYPE public.enrollment_status ADD VALUE 'ARCHIVED';
    END IF;
EXCEPTION
    WHEN others THEN NULL; -- Ignore if value already exists or can't be added in transaction
END $$;

-- 2. Unique Active Enrollment Rule
-- A student cannot have two ACTIVE enrollments in the same academic year
CREATE UNIQUE INDEX IF NOT EXISTS idx_one_active_enrollment_per_year 
ON public.enrollments (student_id, academic_year_id) 
WHERE (status = 'ACTIVE');

-- 3. Enrollment History / Transitions tracking (Optional but recommended for SaaS)
CREATE TABLE IF NOT EXISTS public.enrollment_history (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    enrollment_id UUID REFERENCES public.enrollments(id) ON DELETE CASCADE,
    old_status public.enrollment_status,
    new_status public.enrollment_status,
    changed_by UUID REFERENCES auth.users(id),
    reason TEXT,
    created_at TIMESTAMPTZ DEFAULT now()
);

-- Trigger to log enrollment changes
CREATE OR REPLACE FUNCTION public.log_enrollment_transition()
RETURNS TRIGGER AS $$
BEGIN
    IF (TG_OP = 'UPDATE' AND OLD.status <> NEW.status) THEN
        INSERT INTO public.enrollment_history (enrollment_id, old_status, new_status, changed_by)
        VALUES (OLD.id, OLD.status, NEW.status, auth.uid());
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

DROP TRIGGER IF EXISTS tr_log_enrollment_transition ON public.enrollments;
CREATE TRIGGER tr_log_enrollment_transition
AFTER UPDATE OF status ON public.enrollments
FOR EACH ROW EXECUTE FUNCTION public.log_enrollment_transition();
