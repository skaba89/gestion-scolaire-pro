-- Migrate enrollments.status to ENUM
DO $$ BEGIN
    CREATE TYPE public.enrollment_status AS ENUM ('ACTIVE', 'COMPLETED', 'DROPPED', 'PENDING');
EXCEPTION
    WHEN duplicate_object THEN null;
END $$;

ALTER TABLE public.enrollments RENAME COLUMN status TO status_old;
ALTER TABLE public.enrollments ADD COLUMN status public.enrollment_status DEFAULT 'ACTIVE';

UPDATE public.enrollments SET status = 'ACTIVE' WHERE status_old = 'active';
UPDATE public.enrollments SET status = 'PENDING' WHERE status_old = 'pending';
UPDATE public.enrollments SET status = 'COMPLETED' WHERE status_old = 'completed';
UPDATE public.enrollments SET status = 'DROPPED' WHERE status_old = 'dropped';

ALTER TABLE public.enrollments DROP COLUMN status_old;
