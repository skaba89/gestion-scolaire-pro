# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/schoolflow
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis
REDIS_URL=redis://localhost:6379/0

# Authentication: Native JWT (no external identity provider)

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=CHANGE_ME_IN_PRODUCTION
MINIO_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
MINIO_SECURE=false

# Application
APP_NAME=SchoolFlow Pro API
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# Security
SECRET_KEY=your-secret-key-min-32-characters-long-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin bootstrap
ADMIN_DEFAULT_EMAIL=admin@schoolflow.local
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_IN_PRODUCTION

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3002,http://localhost:5173

# Groq AI (required for AI chat and audit analysis features)
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=4096

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENABLED=true
