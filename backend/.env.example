# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/schoolflow
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis
REDIS_URL=redis://localhost:6379/0

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=schoolflow
KEYCLOAK_CLIENT_ID=schoolflow-backend
KEYCLOAK_CLIENT_SECRET=your-client-secret-here

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# Application
APP_NAME=SchoolFlow Pro API
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# Security
SECRET_KEY=your-secret-key-min-32-characters-long-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:3002,http://localhost:5173

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENABLED=true
