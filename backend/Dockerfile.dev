FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    gcc \
    postgresql-client \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Dev image: docker-compose mounts ./backend over /app. The local startup script
# edits legacy migration files before running Alembic, so the dev container keeps
# default container permissions to avoid host-mounted volume write errors.

EXPOSE 8000

CMD ["bash", "/app/scripts/docker_dev_start.sh"]
