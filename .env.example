# =============================================================================
# SchoolFlow Pro — Variables d'environnement (template)
# =============================================================================
# Copiez ce fichier vers `.env` et remplissez les valeurs.
# Pour Docker : utilisez `.env.docker` (voir .env.docker.example).
#
# Générer des secrets sécurisés :
#   openssl rand -hex 32   → SECRET_KEY
#   openssl rand -hex 16   → mots de passe DB
# =============================================================================

# ─── Application ──────────────────────────────────────────────────────────────
DEBUG=True
LOG_LEVEL=INFO
VITE_APP_VERSION=1.0.0

# ─── Base de données ──────────────────────────────────────────────────────────
# PostgreSQL (production):  DATABASE_URL=postgresql://user:pass@host:5432/db
# SQLite (local dev):       DATABASE_URL=sqlite:///./schoolflow.db
# L'application dérive automatiquement une URL async et une URL sync
# si elles ne sont pas définies.  Utilise psycopg v3 (pas de compilation C).
DATABASE_URL=postgresql://schoolflow:CHANGE_ME@localhost:5432/schoolflow
DATABASE_URL_ASYNC=postgresql+psycopg://schoolflow:CHANGE_ME@localhost:5432/schoolflow
DATABASE_URL_SYNC=postgresql+psycopg://schoolflow:CHANGE_ME@localhost:5432/schoolflow
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ─── Sécurité ─────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
BOOTSTRAP_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
ADMIN_DEFAULT_EMAIL=admin@schoolflow.local
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_min_8_chars

# ─── API Backend ──────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── MinIO (stockage S3-compatible) ───────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_minio_password
MINIO_SECURE=false
MINIO_BUCKET=schoolflow

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ─── Sentry (monitoring erreurs — optionnel) ──────────────────────────────────
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development

# ─── Email SMTP (optionnel — MailHog en dev) ──────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@schoolflow.local

# ─── APIs externes (optionnel) ────────────────────────────────────────────────
RESEND_API_KEY=
STRIPE_SECRET_KEY=
OPENAI_API_KEY=

# ─── RGPD & Conformité ────────────────────────────────────────────────────────
VITE_ENABLE_RGPD_LOGS=true
VITE_DATA_RETENTION_YEARS=5

# ─── Alertes & Monitoring ─────────────────────────────────────────────────────
ALERT_EMAIL=admin@schoolflow.local
ALERT_WEBHOOK=

# ─── Redis (mis en cache, rate limiting) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Groq AI (optionnel — chatbot IA) ───────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=4096

# ─── Déploiement Render (complété automatiquement par Render Blueprint) ──────
# DATABASE_URL       = lié automatiquement à la base Render
# SECRET_KEY         = généré automatiquement par Render
# BACKEND_CORS_ORIGINS=https://schoolflow-frontend.onrender.com
# REDIS_URL=redis://schoolflow-redis:6379/0
# VITE_API_URL=/api-proxy

# ─── Déploiement Netlify (configuré dans le dashboard Netlify) ──────────────
# VITE_API_URL=https://schoolflow-api.onrender.com
# VITE_ENABLE_PWA=false
# VITE_SENTRY_ENVIRONMENT=production

# ─── Dev proxy (optionnel — par défaut localhost:8000) ──────────────────────
# VITE_DEV_PROXY_TARGET=http://localhost:8000
