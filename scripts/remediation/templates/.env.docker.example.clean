# =============================================================================
# SchoolFlow Pro — Variables d'environnement Docker
# =============================================================================
# Copiez ce fichier vers .env.docker et remplissez les valeurs
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=schoolflow
POSTGRES_USER=schoolflow
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_PORT=5432

# ─── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_DB=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=CHANGE_ME_keycloak_db_password
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_keycloak_admin_password
KEYCLOAK_PORT=8080
KEYCLOAK_REALM=schoolflow
KEYCLOAK_CLIENT_ID=schoolflow-frontend
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_client_secret
KEYCLOAK_AUDIENCE=schoolflow-frontend

# ─── MinIO (stockage S3) ──────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password_min_8chars
MINIO_BUCKET=schoolflow
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9001

# ─── Backend API ──────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
API_PORT=8000
DEBUG=True
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://localhost:3000
DATABASE_URL_ASYNC=postgresql+asyncpg://schoolflow:CHANGE_ME_strong_password_here@postgres:5432/schoolflow
DATABASE_URL_SYNC=postgresql+psycopg2://schoolflow:CHANGE_ME_strong_password_here@postgres:5432/schoolflow

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000
VITE_KEYCLOAK_URL=http://localhost:8080

# ─── PgAdmin (optionnel, dev uniquement) ──────────────────────────────────────
PGADMIN_EMAIL=admin@schoolflow.com
PGADMIN_PASSWORD=CHANGE_ME_pgadmin_password
PGADMIN_PORT=5050

# ─── Sauvegardes ──────────────────────────────────────────────────────────────
BACKUP_SCHEDULE=@daily
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6
