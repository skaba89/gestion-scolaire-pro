# =============================================================================
# SchoolFlow Pro — Variables d'environnement (template)
# =============================================================================
# Copiez ce fichier vers `.env` et remplissez les valeurs.
# Pour Docker : utilisez `.env.docker` (voir .env.docker.example).
#
# Générer des secrets sécurisés :
#   openssl rand -hex 32   → SECRET_KEY
#   openssl rand -hex 16   → mots de passe DB
# =============================================================================

# ─── Application ──────────────────────────────────────────────────────────────
DEBUG=True
LOG_LEVEL=INFO
VITE_APP_VERSION=1.0.0

# ─── Base de données PostgreSQL ───────────────────────────────────────────────
# DATABASE_URL sert de valeur de base. L'application dérive automatiquement
# une URL async pour l'API et une URL sync pour Alembic si elles ne sont pas définies.
DATABASE_URL=postgresql://schoolflow:CHANGE_ME@localhost:5432/schoolflow
DATABASE_URL_ASYNC=postgresql+asyncpg://schoolflow:CHANGE_ME@localhost:5432/schoolflow
DATABASE_URL_SYNC=postgresql+psycopg2://schoolflow:CHANGE_ME@localhost:5432/schoolflow
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ─── Sécurité ─────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Keycloak (Identity Provider) ─────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=schoolflow
KEYCLOAK_CLIENT_ID=schoolflow-frontend
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_client_secret
KEYCLOAK_ISSUER=http://localhost:8080/realms/schoolflow
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/schoolflow/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=schoolflow-frontend

# Variables Vite (frontend — doivent commencer par VITE_)
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=schoolflow
VITE_KEYCLOAK_CLIENT_ID=schoolflow-frontend

# ─── API Backend ──────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── MinIO (stockage S3-compatible) ───────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_minio_password
MINIO_SECURE=false
MINIO_BUCKET=schoolflow

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Sentry (monitoring erreurs — optionnel) ──────────────────────────────────
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development

# ─── Email SMTP (optionnel — MailHog en dev) ──────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@schoolflow.local

# ─── APIs externes (optionnel) ────────────────────────────────────────────────
RESEND_API_KEY=
STRIPE_SECRET_KEY=
OPENAI_API_KEY=

# ─── RGPD & Conformité ────────────────────────────────────────────────────────
VITE_ENABLE_RGPD_LOGS=true
VITE_DATA_RETENTION_YEARS=5

# ─── Alertes & Monitoring ─────────────────────────────────────────────────────
ALERT_EMAIL=admin@schoolflow.local
ALERT_WEBHOOK=
