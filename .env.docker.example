# =============================================================================
# SchoolFlow Pro — Variables d'environnement Docker
# =============================================================================
# Copiez ce fichier vers .env.docker et remplacez toutes les valeurs CHANGE_ME.
# Commande recommandée : cp .env.docker.example .env.docker
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=schoolflow
POSTGRES_USER=schoolflow
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_PORT=5432

# ─── MinIO (stockage S3) ──────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password_min_8chars
MINIO_BUCKET=schoolflow
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9001

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password_here
REDIS_PORT=6379

# ─── Bootstrap admin (obligatoire) ────────────────────────────────────────────
# Générer les secrets avec : openssl rand -hex 32
BOOTSTRAP_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
ADMIN_DEFAULT_EMAIL=admin@schoolflow.local
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_min_8_chars

# ─── Backend API ──────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
API_PORT=8000
# DEBUG=True  → démo / dev local : /docs actifs, uvicorn --reload, logs verbeux.
# DEBUG=False → pré-production / production : gunicorn multi-workers, /docs désactivés.
# docker-compose.yml ne force plus cette valeur — c'est CE fichier qui décide.
DEBUG=False
LOG_LEVEL=INFO

# ─── Dimensionnement (petit VPS par défaut) ──────────────────────────────────
# Connexions PostgreSQL max ≈ WORKERS × (POOL_SIZE + MAX_OVERFLOW).
# Défauts prudents : 2 × (5 + 10) = 30 connexions (PostgreSQL accepte 100).
# Sur serveur puissant (4+ vCPU, RAM 8 Go+) : WORKERS=4, POOL_SIZE=10, OVERFLOW=20.
WORKERS=2
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
# Origines CORS : ports du frontend Docker (3000) et du dev Vite (5173)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Les trois URLs doivent pointer vers le même PostgreSQL (host "postgres" dans Docker)
DATABASE_URL=postgresql+psycopg://schoolflow:CHANGE_ME_strong_password_here@postgres:5432/schoolflow
DATABASE_URL_ASYNC=postgresql+psycopg://schoolflow:CHANGE_ME_strong_password_here@postgres:5432/schoolflow
DATABASE_URL_SYNC=postgresql+psycopg://schoolflow:CHANGE_ME_strong_password_here@postgres:5432/schoolflow

# ─── Frontend Docker ──────────────────────────────────────────────────────────
FRONTEND_PORT=3000
# En Docker, le frontend doit appeler Nginx /api, pas localhost:8000
# (docker-compose.yml force de toute façon VITE_API_URL=/api au build).
VITE_API_URL=/api

# ─── PgAdmin (optionnel, dev uniquement) ──────────────────────────────────────
PGADMIN_EMAIL=admin@schoolflow.com
PGADMIN_PASSWORD=CHANGE_ME_pgadmin_password
PGADMIN_PORT=5050

# ─── Redis URL ────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME_redis_password_here@redis:6379/0

# ─── Groq AI (optionnel — chatbot IA & audit) ────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=4096

# ─── OpenRouter AI (optionnel — provider alternatif / fallback) ──────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── Sauvegardes ──────────────────────────────────────────────────────────────
BACKUP_SCHEDULE=@daily
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6
