# =============================================================================
# SchoolFlow Pro — Production Environment Variables
# =============================================================================
# Copy this file and fill in ALL values marked REQUIRED.
# Generate secrets: openssl rand -hex 32
# =============================================================================

# ─── PostgreSQL (REQUIRED) ───────────────────────────────────────────────────
POSTGRES_DB=schoolflow
POSTGRES_USER=schoolflow
POSTGRES_PASSWORD=                    # REQUIRED — openssl rand -hex 16
POSTGRES_PORT=5432

# ─── Database URLs (REQUIRED) ────────────────────────────────────────────────
# Must match POSTGRES_USER/PASSWORD/DB above
DATABASE_URL_ASYNC=postgresql+psycopg://schoolflow:PASSWORD@postgres:5432/schoolflow
DATABASE_URL_SYNC=postgresql+psycopg://schoolflow:PASSWORD@postgres:5432/schoolflow

# ─── Application Security (REQUIRED) ────────────────────────────────────────
SECRET_KEY=                           # REQUIRED — openssl rand -hex 32
BOOTSTRAP_SECRET=                     # REQUIRED — openssl rand -hex 32
ADMIN_DEFAULT_EMAIL=admin@yourschool.com
ADMIN_DEFAULT_PASSWORD=               # REQUIRED — min 12 chars, mixed case + numbers

# ─── Backend API ──────────────────────────────────────────────────────────────
DEBUG=False
LOG_LEVEL=WARNING
API_PORT=8000
ACCESS_TOKEN_EXPIRE_MINUTES=30
BACKEND_CORS_ORIGINS=https://yourfrontend.com  # REQUIRED — your frontend domain

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
# Runtime injection via docker-entrypoint.sh (no rebuild needed):
SCHOOLFLOW_API_URL=https://yourapi.com
SCHOOLFLOW_APP_NAME=SchoolFlow Pro

# ─── Redis (REQUIRED) ────────────────────────────────────────────────────────
REDIS_PASSWORD=                       # REQUIRED — openssl rand -hex 16
REDIS_URL=redis://:PASSWORD@redis:6379/0

# ─── MinIO / S3 Storage ──────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=                  # REQUIRED — min 8 chars
MINIO_BUCKET=schoolflow
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false

# ─── Sentry (recommended) ────────────────────────────────────────────────────
SENTRY_DSN=                           # https://xxx@sentry.io/yyy
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Stripe Billing (optional) ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ─── Groq AI (optional) ─────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Email / SMTP (optional) ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourschool.com

# ─── Push Notifications (optional) ──────────────────────────────────────────
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# ─── Monitoring (optional) ──────────────────────────────────────────────────
METRICS_SECRET=                       # Protect /metrics/ endpoint

# ─── Backups ─────────────────────────────────────────────────────────────────
BACKUP_SCHEDULE=@daily
BACKUP_KEEP_DAYS=30
BACKUP_KEEP_WEEKS=8
BACKUP_KEEP_MONTHS=6

# ─── PgAdmin (debug profile only) ──────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@yourschool.com
PGADMIN_DEFAULT_PASSWORD=
