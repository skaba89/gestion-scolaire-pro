# =============================================================================
# SchoolFlow Pro — SQLite environment for local development (Windows/macOS/Linux)
# =============================================================================
# This template uses SQLite instead of PostgreSQL — no Docker or PG install
# needed.  Perfect for local dev on Windows with Python 3.14.
#
# Usage:
#   1. Copy this file:          copy .env.sqlite .env
#   2. Run migrations:         cd backend && python -m alembic upgrade head
#   3. Create admin user:      python -m scripts.create_admin
#   4. Start the backend:      python -m uvicorn app.main:app --reload --port 8000
# =============================================================================

# ─── Application ──────────────────────────────────────────────────────────────
DEBUG=True
LOG_LEVEL=DEBUG

# ─── Database (SQLite) ───────────────────────────────────────────────────────
# SQLite file-based database.  The file is created automatically on first run.
# For async support, aiosqlite is used (installed via requirements.txt).
DATABASE_URL=sqlite:///./schoolflow.db
DATABASE_URL_ASYNC=sqlite+aiosqlite:///./schoolflow.db
DATABASE_URL_SYNC=sqlite:///./schoolflow.db
DATABASE_POOL_SIZE=
DATABASE_MAX_OVERFLOW=

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=134d4e0a82d65f8f63549c15c84035eb79675fc3130c55e1a083a36b4a1d5805
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── API Backend ──────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── MinIO (storage — disabled for SQLite dev) ────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=schoolflow

# ─── Redis (disabled for SQLite dev — rate limiting and caching skipped) ──────
REDIS_URL=redis://localhost:6379/0

# ─── Groq AI (optional) ──────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=4096

# ─── Sentry (optional — monitoring) ──────────────────────────────────────────
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
